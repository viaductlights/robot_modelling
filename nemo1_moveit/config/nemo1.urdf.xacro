<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="nemo1">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import nemo1 urdf file -->
    <xacro:include filename="$(find nemo1)/urdf/nemo1.urdf" />

    <!-- Import control_xacro -->
    <xacro:include filename="nemo1.ros2_control.xacro" />


    <xacro:nemo1_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
